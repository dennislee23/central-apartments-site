# Block secret files from the web (env + password file + any dotfile starting .ht)
<FilesMatch "^\.(env|ht)">
    Require all denied
</FilesMatch>

# Hide operator-only pages from search engines
<Files "update.html">
    Header always set X-Robots-Tag "noindex, nofollow"
</Files>
<Files "team.html">
    Header always set X-Robots-Tag "noindex, nofollow"
</Files>
<Files "inbox.php">
    Header always set X-Robots-Tag "noindex, nofollow"
</Files>
<Files "learn.php">
    Header always set X-Robots-Tag "noindex, nofollow"
</Files>
<Files "admin.html">
    Header always set X-Robots-Tag "noindex, nofollow"
</Files>
<Files "act.php">
    Header always set X-Robots-Tag "noindex, nofollow"
</Files>
<Files "waiting.php">
    Header always set X-Robots-Tag "noindex, nofollow"
</Files>
<Files "arrivals.php">
    Header always set X-Robots-Tag "noindex, nofollow"
</Files>

# Pretty URLs (admin hub + team guide static; inbox/learn/waiting proxy the worker)
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^admin/?$ admin.html [L]
  RewriteRule ^team/?$ team.html [L]
  RewriteRule ^inbox/tr/?$ inbox.php?tr=1 [L,QSA]
  RewriteRule ^inbox/?$ inbox.php [L]
  RewriteRule ^waiting/?$ waiting.php [L]
  RewriteRule ^arrivals/?$ arrivals.php [L]
  RewriteRule ^learn/act/?$ learn.php [L,QSA]
  RewriteRule ^learn/?$ learn.php [L,QSA]
</IfModule>

# Make the Authorization header visible to PHP (PHP-FPM/CGI doesn't expose it by default)
<IfModule mod_setenvif.c>
  SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1
</IfModule>

# Password-protect the team-only pages (Basic Auth).
# AuthUserFile must be an ABSOLUTE filesystem path, which differs per server.
# deploy.php fills it in automatically on each deploy by replacing the
# placeholder token on the AuthUserFile line below with the real absolute path.
<Files "team.html">
    AuthType Basic
    AuthName "Central Apartments - team only"
    AuthUserFile "__HTPASSWD_PATH__"
    Require valid-user
</Files>
<Files "inbox.php">
    AuthType Basic
    AuthName "Central Apartments - team only"
    AuthUserFile "__HTPASSWD_PATH__"
    Require valid-user
</Files>
<Files "learn.php">
    AuthType Basic
    AuthName "Central Apartments - team only"
    AuthUserFile "__HTPASSWD_PATH__"
    Require valid-user
</Files>
<Files "admin.html">
    AuthType Basic
    AuthName "Central Apartments - team only"
    AuthUserFile "__HTPASSWD_PATH__"
    Require valid-user
</Files>
<Files "act.php">
    AuthType Basic
    AuthName "Central Apartments - team only"
    AuthUserFile "__HTPASSWD_PATH__"
    Require valid-user
</Files>
<Files "waiting.php">
    AuthType Basic
    AuthName "Central Apartments - team only"
    AuthUserFile "__HTPASSWD_PATH__"
    Require valid-user
</Files>
<Files "arrivals.php">
    AuthType Basic
    AuthName "Central Apartments - team only"
    AuthUserFile "__HTPASSWD_PATH__"
    Require valid-user
</Files>

# Short cache for HTML so updates appear fast; long cache for hashed assets
<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "max-age=300, must-revalidate"
  </FilesMatch>
</IfModule>

# Block the .git directory from the web
RedirectMatch 404 /\.git
